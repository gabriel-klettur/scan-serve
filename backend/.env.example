# Backend configuration (FastAPI)
# Pydantic Settings uses RV_ prefix.

# Comma-separated list of allowed origins for CORS.
# Example for local dev with Vite on :8080
RV_CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]

# Optional: change API prefix if needed
RV_API_V1_PREFIX=/api/v1

# Optional: override uploads directory (defaults to backend/uploads)
# RV_UPLOADS_DIR=uploads
