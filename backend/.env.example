# Backend configuration (FastAPI)
# Pydantic Settings uses RV_ prefix.

# Comma-separated list of allowed origins for CORS.
# Example for local dev with Vite on :8080
RV_CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]

# Optional: change API prefix if needed
RV_API_V1_PREFIX=/api/v1

# Optional: override uploads directory (defaults to backend/uploads)
# RV_UPLOADS_DIR=uploads

# Google Vision OCR (API key auth)
# GOOGLE_VISION_OCR_API_KEY=<your_google_cloud_api_key>
# VISION_LANGUAGE_HINTS=["is","en"]

# OpenAI (used by /api/v1/ocr/ai/parse)
# GPT_5_MINI_API=<your_openai_api_key>
RV_OPENAI_RECEIPT_MODEL=gpt-5-nano

# Optional: per-agent model overrides
# RV_OPENAI_RECEIPT_ORGANIZER_MODEL=gpt-5-mini
# RV_OPENAI_RECEIPT_AUDITOR_MODEL=gpt-5-mini
# RV_OPENAI_RECEIPT_STYLIST_MODEL=gpt-5-mini

# Optional: retries if the model returns invalid JSON
RV_OPENAI_RECEIPT_JSON_RETRIES=1

